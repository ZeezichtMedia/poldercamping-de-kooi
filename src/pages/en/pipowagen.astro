---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<Layout title="Pipowagen">
  <PageHeader 
    title="Sleeping in a Gypsy Wagon" 
    subtitle="Unique overnight stay in the polder"
    image="/images/pipowagen-hero.png"
  />

  <main class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <div class="prose prose-lg prose-stone mx-auto text-center mb-16">
        <h2 class="text-3xl font-bold text-polder-green mb-6">Atmospheric & Comfortable</h2>
        <p>
          Do you want to experience the camping feeling, but don't have your own camping equipment? Or do you just love something special? Rent our atmospheric <strong>gypsy wagon</strong>.
        </p>
        <p>
          The wagons are tastefully decorated and are located on a beautiful spot on the campsite with an unobstructed view. Just like the camping spots, you also have your <strong>own private sanitary facilities</strong> here.
        </p>
      </div>

      <!-- Feature Images Grid -->
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="rounded-2xl overflow-hidden shadow-xl h-96">
          <img 
            src="/images/pipowagen-binnen-1.png" 
            alt="Interieur Pipowagen" 
            class="w-full h-full object-cover"
          />
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl h-96">
          <img 
            src="/images/pipowagen-binnen-2.png" 
            alt="Interieur Pipowagen Detail" 
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-stone-50 p-8 rounded-2xl border border-stone-100">
          <h3 class="text-xl font-bold text-polder-green mb-4">Amenities</h3>
          <ul class="space-y-3 text-stone-700">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-polder-orange rounded-full"></span>
              Comfortable double bed
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-polder-orange rounded-full"></span>
              Sitting area with table and chairs
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-polder-orange rounded-full"></span>
              Small kitchen (coffee/tea facilities)
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-polder-orange rounded-full"></span>
              Private terrace
            </li>
             <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-polder-orange rounded-full"></span>
              Private sanitary unit (shower/toilet)
            </li>
          </ul>
        </div>
        
        <div class="bg-stone-50 p-8 rounded-2xl border border-stone-100 flex flex-col justify-center">
          <h3 class="text-xl font-bold text-polder-green mb-4">Rates & Availability</h3>
          <p class="mb-6 text-stone-600">
            Curious about the costs and when you can come to sleep in these unique wagons? Contact us for current availability.
          </p>
          <a href="/en/contact" class="bg-polder-orange text-center text-white font-bold py-3 px-6 rounded-full hover:bg-polder-orange-dark transition-colors">
            Request Information
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
