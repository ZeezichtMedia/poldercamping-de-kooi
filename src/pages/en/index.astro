---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/home/Hero.astro';
import Features from '../../components/home/Features.astro';
import Welcome from '../../components/home/Welcome.astro';
---

<Layout title="Home">
  <main class="min-h-screen">
    <Hero 
      title="Peace & Space in the <span class='text-polder-orange'>Polder</span>"
      subtitle="Enjoy the outdoors with private sanitary facilities and a panoramic view of the Green Heart of Utrecht."
      ctaPrimary="Book a Spot"
      ctaSecondary="Discover Camping"
      ctaPrimaryLink="/en/book"
      ctaSecondaryLink="/en/camping"
    />
    <Features 
      title="Why De Kooi?"
      subtitle="Experience the luxury of <span class='text-polder-orange'>simplicity</span>"
      features={[
        {
          title: "Private Sanitary",
          description: "Enjoy your own shower, toilet and sink directly at your camping spot. No shared facilities, but pure privacy."
        },
        {
          title: "Small & Quiet",
          description: "With only 7 camping spots and 2 gypsy wagons you experience ultimate peace. No wifi, but singing birds."
        },
        {
          title: "Unique Location",
          description: "In the middle of the polder, but within 20 minutes cycling at the Dom Square of Utrecht. The best of both worlds."
        },
        {
          title: "Farm Life",
          description: "Wake up with a view of cows, sheep and the Westbroek windmill. A real farm camping experience."
        }
      ]}
    />
    <Welcome 
      tagline="Welcome to De Kooi"
      title='"Coming home in the polder, away from it all."'
      paragraph1='In the beautiful village of Westbroek we, <strong class="text-polder-green">Wim and Wilma van Barneveld</strong>, run our small-scale polder campsite. Since the summer of 2022 we welcome you warmly to our yard.'
      paragraph2="On our campsite you won't find wifi, a canteen or an animation team. What will you find? Unprecedented peace, a wide view and the coziness of farm life."
      paragraph3="Whether you come with your caravan, camper, tent, or choose one of our gypsy wagons: you are always front-row with a view of the polder and the windmill."
      signature="Wim & Wilma"
    />
    
    <!-- CTA Section -->
    <section class="py-20 bg-polder-green text-white text-center">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready for the polder?</h2>
        <p class="text-xl text-stone-300 mb-8 max-w-2xl mx-auto">
          Reserve your spot now and ensure yourself a relaxing holiday with private sanitary facilities.
        </p>
        <div class="flex justify-center gap-4">
           <a href="/en/book" class="bg-polder-orange hover:bg-polder-orange-dark text-white text-lg font-semibold px-8 py-4 rounded-full shadow-lg transition-transform hover:scale-105">
            Book Now
          </a>
          <a href="/en/tarieven" class="bg-transparent border border-white hover:bg-white/10 text-white text-lg font-semibold px-8 py-4 rounded-full transition-colors">
            View Rates
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
