---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<Layout title="Reservieren">
  <PageHeader 
    title="Reservieren" 
    subtitle="Buchen Sie Ihren Aufenthalt im Polder"
  />

  <main class="container mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-stone-200">
      <h2 class="text-3xl font-bold text-polder-green mb-6">Anfrage Senden</h2>
      <p class="text-stone-600 mb-8">
        Füllen Sie das untenstehende Formular aus, um eine Reservierungsanfrage zu senden. Wir werden uns so schnell wie möglich bei Ihnen melden, um die Reservierung zu bestätigen.
      </p>

      <form class="space-y-6" id="reservation-form">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-stone-700 font-bold mb-2">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="Ihr Name">
          </div>
          <div>
            <label for="email" class="block text-stone-700 font-bold mb-2">E-Mail</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="ihre@email.de">
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="phone" class="block text-stone-700 font-bold mb-2">Telefon</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="+49 12345678">
          </div>
          <div>
            <label for="persons" class="block text-stone-700 font-bold mb-2">Personenanzahl</label>
            <select id="persons" name="persons" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
              <option value="1">1 Person</option>
              <option value="2" selected>2 Personen</option>
              <option value="3">3 Personen</option>
              <option value="4">4 Personen</option>
              <option value="5+">Mehr als 4</option>
            </select>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="arrival" class="block text-stone-700 font-bold mb-2">Anreisedatum</label>
            <input type="date" id="arrival" name="arrival" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
          </div>
          <div>
            <label for="departure" class="block text-stone-700 font-bold mb-2">Abreisedatum</label>
            <input type="date" id="departure" name="departure" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
          </div>
        </div>

        <div>
          <label for="type" class="block text-stone-700 font-bold mb-2">Unterkunftstyp</label>
          <select id="type" name="type" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
            <option value="kampeerplek">Stellplatz (Wohnwagen/Zelt/Wohnmobil)</option>
            <option value="pipowagen">Zirkuswagen</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-stone-700 font-bold mb-2">Bemerkungen / Fragen</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="Ankunftszeit, besondere Wünsche, etc."></textarea>
        </div>

        <button type="submit" class="w-full bg-polder-orange text-white font-bold text-lg py-4 rounded-xl hover:bg-polder-orange-dark transition-colors shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all">
          Anfrage Senden
        </button>
      </form>
    </div>
  </main>

  <script>
    const form = document.getElementById('reservation-form');
    
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target as HTMLFormElement);
      const data = Object.fromEntries(formData);
      
      const subject = `Reservierungsanfrage: ${data.name}`;
      const body = `
Name: ${data.name}
Email: ${data.email}
Telefon: ${data.phone}
Personen: ${data.persons}
Anreise: ${data.arrival}
Abreise: ${data.departure}
Typ: ${data.type}

Nachricht:
${data.message}
      `.trim();

      window.location.href = `mailto:poldercampingdekooi@outlook.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</Layout>
