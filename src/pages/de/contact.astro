---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<Layout title="Contact">
  <PageHeader title="Kontakt" subtitle="Wir hören gerne von Ihnen" />

  <main class="container mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 gap-16 max-w-6xl mx-auto">
      <!-- Contact Info -->
      <div>
        <h2 class="text-3xl font-bold text-polder-green mb-8">Kontaktdaten</h2>

        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="bg-polder-orange/10 p-4 rounded-full">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6 text-polder-orange"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-stone-800 text-lg mb-1">Adresse</h3>
              <p class="text-stone-600 text-lg">
                Dokter Welfferweg 110<br />
                3615 AR Westbroek<br />
                Utrecht, Niederlande
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="bg-polder-orange/10 p-4 rounded-full">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6 text-polder-orange"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-stone-800 text-lg mb-1">Telefon</h3>
              <p class="text-stone-600 text-lg mb-2">
                <a
                  href="tel:+31623140717"
                  class="hover:text-polder-orange transition-colors"
                  >06 - 23 14 07 17</a
                > (09:00 - 18:00)
              </p>
              <p class="text-stone-600 text-lg">
                <a
                  href="tel:+31623296050"
                  class="hover:text-polder-orange transition-colors"
                  >06 - 23 29 60 50</a
                > (Keine Antwort)
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="bg-polder-orange/10 p-4 rounded-full">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6 text-polder-orange"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-stone-800 text-lg mb-1">E-mail</h3>
              <p class="text-stone-600 text-lg">
                <a
                  href="mailto:poldercampingdekooi@outlook.com"
                  class="hover:text-polder-orange transition-colors underline decoration-stone-300 underline-offset-4"
                >
                  poldercampingdekooi@outlook.com
                </a>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Standort / Map -->
      <div class="bg-stone-50 p-8 rounded-3xl border border-stone-200 h-fit">
        <h2 class="text-2xl font-bold text-polder-green mb-6">Standort</h2>
        <div
          class="rounded-xl overflow-hidden h-64 bg-stone-200 shadow-inner mb-4"
        >
          <!-- Placeholder for Google Maps Embed -->
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2448.971367345678!2d5.1111!3d52.1234!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTLCsDA3JzM1LjMiTiA1wrAwNyc0My40IkU!5e0!3m2!1snl!2snl!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
          ></iframe>
        </div>
        <a
          href="https://www.google.com/maps/place/Dokter+Welfferweg+110,+3615+AR+Westbroek,+Nederland/@52.1477315,5.1417681,17.25z/data=!4m15!1m8!3m7!1s0x47c66eb4837f6241:0x9475ed2d179e0bc7!2sDokter+Welfferweg+110,+3615+AR+Westbroek,+Nederland!3b1!8m2!3d52.1480833!4d5.1441247!16s%2Fg%2F11c5l99j3c!3m5!1s0x47c66eb4837f6241:0x9475ed2d179e0bc7!8m2!3d52.1480833!4d5.1441247!16s%2Fg%2F11c5l99j3c?hl=nl&entry=ttu&g_ep=EgoyMDI2MDMwMi4wIKXMDSoASAFQAw%3D%3D"
          target="_blank"
          class="block text-center text-sm text-stone-500 hover:text-polder-orange flex items-center justify-center gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-4 h-4"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
            ></path>
          </svg>
          In Google Maps öffnen
        </a>
      </div>
    </div>
  </main>
</Layout>
