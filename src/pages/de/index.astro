---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/home/Hero.astro";
import Features from "../../components/home/Features.astro";
import Welcome from "../../components/home/Welcome.astro";
---

<Layout title="Home">
  <main class="min-h-screen">
    <Hero
      title="Ruhe & Raum im <span class='text-polder-orange'>Polder</span>"
      subtitle="Genießen Sie das Landleben mit privaten Sanitäranlagen und einem Panoramablick auf das Grüne Herz von Utrecht."
      ctaPrimary="Platz reservieren"
      ctaSecondary="Camping entdecken"
      ctaPrimaryLink="/de/reservieren"
      ctaSecondaryLink="/de/camping"
    />
    <Features
      title="Warum De Kooi?"
      subtitle="Erleben Sie den Luxus der <span class='text-polder-orange'>Einfachheit</span>"
      features={[
        {
          title: "Privatsanitär",
          description:
            "Genießen Sie Ihre eigene Dusche, Toilette und Waschbecken direkt am Stellplatz. Keine gemeinschaftlichen Einrichtungen, sondern pure Privatsphäre.",
        },
        {
          title: "Klein & Ruhig",
          description:
            "Mit 5 geräumigen Stellplätzen, 3 Wohnmobilstellplätzen und 2 Zirkuswagen erleben Sie hier ultimative Ruhe. Kein Animationsteam, dafür singende Vögel.",
        },
        {
          title: "Einzigartige Lage",
          description:
            "Mitten im Polder, aber nur 20 Fahrradminuten vom Domplatz in Utrecht entfernt. Das Beste aus zwei Welten.",
        },
        {
          title: "Bauernleben",
          description:
            "Aufwachen mit Blick auf Kühe, Schafe und die Mühle von Westbroek. Ein echtes Bauernhof-Camping-Erlebnis.",
        },
      ]}
    />
    <Welcome
      tagline="Willkommen bei De Kooi"
      title='"Nach Hause kommen im Polder, einfach mal weg von allem."'
      paragraph1='Im schönen Dorf Westbroek führen wir, <strong class="text-polder-green">Wim und Wilma van Barneveld</strong>, unseren kleinen Polder-Campingplatz. Seit dem Sommer 2022 heißen wir Sie herzlich auf unserem Hof willkommen.'
      paragraph2="Auf unserem Campingplatz finden Sie kein WLAN, keine Kantine und kein Animationsteam. Was finden Sie? Ungeahnte Ruhe, einen weiten Blick und die Gemütlichkeit des Bauernlebens."
      paragraph3="Ob Sie mit Wohnwagen, Wohnmobil, Zelt kommen oder einen unserer Zirkuswagen wählen: Sie stehen immer in der ersten Reihe mit Blick auf den Polder und die Mühle."
      signature="Wim & Wilma"
    />

    <!-- CTA Section -->
    <section class="py-20 bg-polder-green text-white text-center">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Bereit für den Polder?
        </h2>
        <p class="text-xl text-stone-300 mb-8 max-w-2xl mx-auto">
          Reservieren Sie jetzt Ihren Platz und sichern Sie sich einen
          entspannten Urlaub mit Privatsanitär.
        </p>
        <div class="flex justify-center gap-4">
          <a
            href="/de/reservieren"
            class="bg-polder-orange hover:bg-polder-orange-dark text-white text-lg font-semibold px-8 py-4 rounded-full shadow-lg transition-transform hover:scale-105"
          >
            Jetzt Buchen
          </a>
          <a
            href="/de/tarieven"
            class="bg-transparent border border-white hover:bg-white/10 text-white text-lg font-semibold px-8 py-4 rounded-full transition-colors"
          >
            Preise ansehen
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
