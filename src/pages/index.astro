---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Features from '../components/home/Features.astro';
import Welcome from '../components/home/Welcome.astro';
---

<Layout title="Home">
  <main class="min-h-screen">
    <Hero 
      ctaPrimaryLink="/reserveren"
      ctaSecondaryLink="/camping"
    />
    <Features />
    <Welcome />
    
    <!-- CTA Section -->
    <section class="py-20 bg-polder-green text-white text-center">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Klaar voor de polder?</h2>
        <p class="text-xl text-stone-300 mb-8 max-w-2xl mx-auto">
          Reserveer nu uw plekje en verzeker uzelf van een ontspannen vakantie met privé sanitair.
        </p>
        <div class="flex justify-center gap-4">
           <a href="/reserveren" class="bg-polder-orange hover:bg-polder-orange-dark text-white text-lg font-semibold px-8 py-4 rounded-full shadow-lg transition-transform hover:scale-105">
            Reserveer Nu
          </a>
          <a href="/tarieven" class="bg-transparent border border-white hover:bg-white/10 text-white text-lg font-semibold px-8 py-4 rounded-full transition-colors">
            Bekijk Tarieven
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
