---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Layout title="De Camping">
  <PageHeader
    title="Kamperen bij de Boer"
    subtitle="Ruime plekken met privé sanitair"
    image="/images/new img/camping-veld-campers-en-prive-sanitair.jpeg"
    imagePosition="object-center md:object-[50%_35%]"
  />

  <main class="container mx-auto px-4 py-16">
    <!-- Intro -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-3xl font-bold text-polder-green mb-6">Comfort en Rust</h2>
      <p class="text-lg text-stone-600 leading-relaxed mb-4">
        Onze camping beschikt over 5 ruime comfortplekken. Elke plek is voorzien
        van elektra (10 ampère). Het absolute hoogtepunt is uw eigen privésanitair unit direct bij uw plek.
      </p>
      <p class="text-lg text-polder-orange font-bold leading-relaxed">
        Nieuw dit jaar: 3 verharde camperplekken met gezamenlijk sanitair.
      </p>
    </div>

    <!-- Features Grid (Specific to Camping) -->
    <div class="grid md:grid-cols-2 gap-12 mb-20">
      <div
        class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden"
      >
        <div class="h-64 bg-stone-200 relative group">
          <img
            src="/images/prive-sanitair-custom.jpg"
            alt="Privé Sanitair Unit"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold text-polder-green mb-4">
            Privé Sanitair
          </h3>
          <p class="text-stone-600 mb-4">
            U hoeft nooit meer met uw wc-rol over de camping. Uw eigen unit
            beschikt over:
          </p>
          <ul class="space-y-2 text-stone-600">
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              Toilet
            </li>
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              Warme douche
            </li>
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              Wastafel & spiegel
            </li>
          </ul>
        </div>
      </div>

      <div
        class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden"
      >
        <div class="h-64 bg-stone-200 relative group">
          <img
            src="/images/new img/caravan-met-oranje-luifel-bij-zonsondergang.jpeg"
            alt="Gezellige kampeerplek bij zonsondergang"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold text-polder-green mb-4">De Plekken</h3>
          <p class="text-stone-600 mb-4">
            Onze 5 comfortplekken zijn verhard en omgeven door gras. U kijkt weids uit
            over de weilanden. Daarnaast bieden wij 3 nieuwe verharde camperplekken (zonder privé sanitair).
          </p>
          <ul class="space-y-2 text-stone-600">
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              Geschikt voor caravan, camper en tent
            </li>
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              10 ampère stroom (inclusief)
            </li>
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              Gratis wifi-vrije zone (echte rust!)
            </li>
            <li class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5 text-polder-orange"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"></path></svg
              >
              Geen honden toegestaan
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Facilities List / Other Info -->
    <div class="bg-stone-50 rounded-2xl p-8 md:p-12">
      <h3 class="text-2xl font-bold text-polder-green mb-6">
        Overige Faciliteiten
      </h3>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="flex items-start gap-4">
          <div class="bg-white p-3 rounded-full shadow-sm">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 text-polder-green"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
              ></path>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-stone-800">Stroom Inclusief</h4>
            <p class="text-sm text-stone-600">
              Geen gedoe met muntjes of meters.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="bg-white p-3 rounded-full shadow-sm">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 text-polder-green"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
              ></path>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-stone-800">Weids Uitzicht</h4>
            <p class="text-sm text-stone-600">Zicht op de molen en Domtoren.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="bg-white p-3 rounded-full shadow-sm">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 text-polder-green"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
              ></path>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-stone-800">Informatie</h4>
            <p class="text-sm text-stone-600">Let op: Geen stortplaats voor afvalwater aanwezig.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
