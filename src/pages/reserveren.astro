---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Reserveren">
  <PageHeader 
    title="Reserveren" 
    subtitle="Boek uw verblijf in de polder"
  />

  <main class="container mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-stone-200">
      <h2 class="text-3xl font-bold text-polder-green mb-6">Aanvraag Versturen</h2>
      <p class="text-stone-600 mb-8">
        Vul onderstaand formulier in om een reserveringsaanvraag te doen. Wij nemen zo spoedig mogelijk contact met u op om de reservering te bevestigen.
      </p>

      <form class="space-y-6" id="reservation-form">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-stone-700 font-bold mb-2">Naam</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="Uw naam">
          </div>
          <div>
            <label for="email" class="block text-stone-700 font-bold mb-2">E-mail</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="uw@email.nl">
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="phone" class="block text-stone-700 font-bold mb-2">Telefoonnummer</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="06 12345678">
          </div>
          <div>
            <label for="persons" class="block text-stone-700 font-bold mb-2">Aantal Personen</label>
            <select id="persons" name="persons" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
              <option value="1">1 Persoon</option>
              <option value="2" selected>2 Personen</option>
              <option value="3">3 Personen</option>
              <option value="4">4 Personen</option>
              <option value="5+">Meer dan 4</option>
            </select>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="arrival" class="block text-stone-700 font-bold mb-2">Aankomstdatum</label>
            <input type="date" id="arrival" name="arrival" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
          </div>
          <div>
            <label for="departure" class="block text-stone-700 font-bold mb-2">Vertrekdatum</label>
            <input type="date" id="departure" name="departure" required class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
          </div>
        </div>

        <div>
          <label for="type" class="block text-stone-700 font-bold mb-2">Onderkomen</label>
          <select id="type" name="type" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all">
            <option value="kampeerplek">Kampeerplek (Caravan/Tent/Camper)</option>
            <option value="pipowagen">Pipowagen</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-stone-700 font-bold mb-2">Opmerkingen / Vragen</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl bg-stone-50 border border-stone-200 focus:outline-none focus:ring-2 focus:ring-polder-orange/50 focus:border-polder-orange transition-all" placeholder="Bijv. aankomsttijd, elektra nodig, etc."></textarea>
        </div>

        <button type="submit" class="w-full bg-polder-orange text-white font-bold text-lg py-4 rounded-xl hover:bg-polder-orange-dark transition-colors shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all">
          Verstuur Aanvraag
        </button>
      </form>
    </div>
  </main>

  <script>
    const form = document.getElementById('reservation-form');
    
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target as HTMLFormElement);
      const data = Object.fromEntries(formData);
      
      const subject = `Reserveringsaanvraag: ${data.name}`;
      const body = `
Naam: ${data.name}
Email: ${data.email}
Telefoon: ${data.phone}
Aantal Personen: ${data.persons}
Aankomst: ${data.arrival}
Vertrek: ${data.departure}
Type: ${data.type}

Opmerkingen:
${data.message}
      `.trim();

      window.location.href = `mailto:poldercampingdekooi@outlook.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</Layout>
