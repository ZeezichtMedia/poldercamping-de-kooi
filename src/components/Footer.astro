---
const currentYear = new Date().getFullYear();
---

<footer class="bg-polder-green text-stone-300 py-12">
  <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Brand -->
    <div>
      <h3 class="text-white text-xl font-bold mb-4">Poldercamping De Kooi</h3>
      <p class="text-stone-400 mb-4">
        Geniet van rust, ruimte en het boerenleven in de prachtige polder van Westbroek.
      </p>
      <div class="flex items-center gap-3">
         <img src="/images/svr-logo.png" alt="SVR Logo" class="h-12 w-auto" />
         <span class="text-sm font-medium opacity-90">Aangesloten bij SVR</span>
      </div>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-white text-lg font-bold mb-4">Contact</h3>
      <ul class="space-y-2">
        <li class="flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mt-1 text-polder-orange">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <span>Dokter Welfferweg 110<br/>3615 AR Westbroek</span>
        </li>
        <li class="flex items-center gap-2">
           <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-polder-orange">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <a href="tel:+31623140717" class="hover:text-white">06-23140717</a>
        </li>
        <li class="flex items-center gap-2">
           <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-polder-orange">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <a href="mailto:poldercampingdekooi@outlook.com" class="hover:text-white">poldercampingdekooi@outlook.com</a>
        </li>
      </ul>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="text-white text-lg font-bold mb-4">Navigatie</h3>
      <ul class="space-y-2">
        <li><a href="/camping" class="hover:text-polder-orange transition-colors">De Camping</a></li>
        <li><a href="/pipowagens" class="hover:text-polder-orange transition-colors">Pipowagens</a></li>
        <li><a href="/omgeving" class="hover:text-polder-orange transition-colors">Omgeving</a></li>
        <li><a href="/tarieven" class="hover:text-polder-orange transition-colors">Tarieven</a></li>
      </ul>
    </div>
  </div>
  
  <div class="border-t border-polder-green-dark mt-12 pt-8 text-center text-sm text-stone-500">
    <p>&copy; {currentYear} Poldercamping De Kooi. Alle rechten voorbehouden.</p>
  </div>
</footer>
