---
interface Props {
  title?: string;
  subtitle?: string;
  ctaPrimary?: string;
  ctaSecondary?: string;
  ctaPrimaryLink?: string;
  ctaSecondaryLink?: string;
}

const {
  title = "Rust & Ruimte in de <span class='text-polder-orange'>Polder</span>",
  subtitle = "Geniet van het buitenleven met privé sanitair en een weids uitzicht over het groene hart van Utrecht.",
  ctaPrimary = "Reserveer een Plek",
  ctaSecondary = "Ontdek de Camping",
  ctaPrimaryLink = "/reserveren",
  ctaSecondaryLink = "/camping"
} = Astro.props;
---

<section class="relative h-[85vh] min-h-[650px] flex items-center justify-center overflow-hidden">
  <!-- Background Image with Premium Overlay -->
  <div class="absolute inset-0 z-0 bg-polder-green-dark">
    <img 
      src="/images/hero-new.jpg" 
      alt="Luxe sfeer op Poldercamping De Kooi" 
      class="w-full h-full object-cover animate-[pulse_10s_ease-in-out_infinite_alternate]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/10 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto transform translate-y-4 animate-[fade-in-up_1s_ease-out_forwards]">
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-6 drop-shadow-2xl leading-[1.1] tracking-tight" set:html={title} />
    <p class="text-xl md:text-2xl mb-12 max-w-2xl mx-auto drop-shadow-lg text-stone-200 font-normal leading-relaxed">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a 
        href={ctaPrimaryLink} 
        class="bg-gradient-to-r from-polder-orange to-[#e68a19] hover:from-[#e68a19] hover:to-polder-orange text-white text-lg font-bold px-10 py-4 rounded-full transition-all duration-300 hover:-translate-y-1 shadow-[0_10px_40px_-10px_rgba(217,119,6,0.5)] border border-white/10"
      >
        {ctaPrimary}
      </a>
      <a 
        href={ctaSecondaryLink} 
        class="bg-white/5 hover:bg-white/10 backdrop-blur-xl text-white border border-white/20 text-lg font-semibold px-10 py-4 rounded-full transition-all duration-300 hover:-translate-y-1 shadow-[0_10px_40px_-10px_rgba(0,0,0,0.3)]"
      >
        {ctaSecondary}
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-white/80">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
