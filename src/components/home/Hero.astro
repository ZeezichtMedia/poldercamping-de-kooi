---
interface Props {
  title?: string;
  subtitle?: string;
  ctaPrimary?: string;
  ctaSecondary?: string;
  ctaPrimaryLink?: string;
  ctaSecondaryLink?: string;
}

const {
  title = "Rust & Ruimte in de <span class='text-polder-orange'>Polder</span>",
  subtitle = "Geniet van het buitenleven met privé sanitair en een weids uitzicht over het groene hart van Utrecht.",
  ctaPrimary = "Reserveer een Plek",
  ctaSecondary = "Ontdek de Camping",
  ctaPrimaryLink = "/reserveren",
  ctaSecondaryLink = "/camping"
} = Astro.props;
---

<section class="relative h-[80vh] min-h-[600px] flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero.png" 
      alt="Polderlandschap met molen en tent" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/30 to-black/10"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
    <h1 class="text-5xl md:text-7xl font-bold mb-6 drop-shadow-lg leading-tight" set:html={title} />
    <p class="text-xl md:text-2xl mb-10 max-w-2xl mx-auto drop-shadow-md font-light">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a 
        href={ctaPrimaryLink} 
        class="bg-polder-orange hover:bg-polder-orange-dark text-white text-lg font-semibold px-8 py-4 rounded-full transition-transform hover:scale-105 shadow-lg"
      >
        {ctaPrimary}
      </a>
      <a 
        href={ctaSecondaryLink} 
        class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/50 text-lg font-semibold px-8 py-4 rounded-full transition-colors"
      >
        {ctaSecondary}
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-white/80">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
