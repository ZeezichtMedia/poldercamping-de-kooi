---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  features?: Feature[];
}

const {
  title = "Waarom De Kooi?",
  subtitle = "Ervaar de luxe van <span class='text-polder-orange'>eenvoud</span>",
  features = [
    {
      title: "Privé Sanitair",
      description:
        "Geniet van uw eigen douche, toilet en wastafel direct bij de kampeerplek. Geen gedeelde voorzieningen, maar pure privacy.",
    },
    {
      title: "Klein & Rustig",
      description:
        "Met 5 ruime kampeerplekken, 3 camperplekken en een pipowagen ervaart u ultieme rust. Geen animatieteam, wel zingende weidevogels.",
    },
    {
      title: "Unieke Locatie",
      description:
        "Midden in de polder, maar binnen 20 minuten fietsen op het Domplein van Utrecht. Het beste van twee werelden.",
    },
    {
      title: "Polderleven",
      description:
        "Wakker worden met uitzicht op koeien, schapen en de Westbroekse molen. Een echte boerencamping ervaring.",
    },
  ],
} = Astro.props;
---

<section class="py-20 bg-stone-50" id="features">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-16 px-4">
      <h2
        class="text-polder-orange text-sm font-bold uppercase tracking-widest mb-3"
      >
        {title}
      </h2>
      <h3
        class="text-4xl md:text-5xl font-extrabold text-stone-800 tracking-tight"
        set:html={subtitle}
      />
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Feature 1 -->
      <div
        class="bg-white p-8 rounded-2xl shadow-lg shadow-stone-200/40 border border-stone-100/50 hover:shadow-xl hover:shadow-stone-200/60 transition-all duration-300 hover:-translate-y-1 group relative overflow-hidden"
      >
        <!-- Shine effect on hover -->
        <div
          class="absolute inset-0 translate-x-[-100%] bg-gradient-to-r from-transparent via-white/40 to-transparent group-hover:animate-[shine_1.5s_ease-in-out]"
        >
        </div>
        <div
          class="w-14 h-14 bg-gradient-to-br from-polder-green/10 to-transparent rounded-xl flex items-center justify-center mb-6 group-hover:from-polder-green/20 group-hover:scale-110 transition-all duration-300 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8 text-polder-green"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205 3 1m1.5.5-1.5-.5M6.75 7.364V3h-3v18m3-13.636 10.5-3.819"
            ></path>
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">
          {features[0].title}
        </h4>
        <p class="text-stone-600 leading-relaxed">
          {features[0].description}
        </p>
      </div>

      <!-- Feature 2 -->
      <div
        class="bg-white p-8 rounded-2xl shadow-lg shadow-stone-200/40 border border-stone-100/50 hover:shadow-xl hover:shadow-stone-200/60 transition-all duration-300 hover:-translate-y-1 group relative overflow-hidden"
      >
        <!-- Shine effect on hover -->
        <div
          class="absolute inset-0 translate-x-[-100%] bg-gradient-to-r from-transparent via-white/40 to-transparent group-hover:animate-[shine_1.5s_ease-in-out]"
        >
        </div>
        <div
          class="w-14 h-14 bg-gradient-to-br from-polder-orange/10 to-transparent rounded-xl flex items-center justify-center mb-6 group-hover:from-polder-orange/20 group-hover:scale-110 transition-all duration-300 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8 text-polder-orange"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
            ></path>
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">
          {features[1].title}
        </h4>
        <p class="text-stone-600 leading-relaxed">
          {features[1].description}
        </p>
      </div>

      <!-- Feature 3 -->
      <div
        class="bg-white p-8 rounded-2xl shadow-lg shadow-stone-200/40 border border-stone-100/50 hover:shadow-xl hover:shadow-stone-200/60 transition-all duration-300 hover:-translate-y-1 group relative overflow-hidden"
      >
        <!-- Shine effect on hover -->
        <div
          class="absolute inset-0 translate-x-[-100%] bg-gradient-to-r from-transparent via-white/40 to-transparent group-hover:animate-[shine_1.5s_ease-in-out]"
        >
        </div>
        <div
          class="w-14 h-14 bg-gradient-to-br from-polder-green/10 to-transparent rounded-xl flex items-center justify-center mb-6 group-hover:from-polder-green/20 group-hover:scale-110 transition-all duration-300 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8 text-polder-green"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path>
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">
          {features[2].title}
        </h4>
        <p class="text-stone-600 leading-relaxed">
          {features[2].description}
        </p>
      </div>

      <!-- Feature 4 -->
      <div
        class="bg-white p-8 rounded-2xl shadow-lg shadow-stone-200/40 border border-stone-100/50 hover:shadow-xl hover:shadow-stone-200/60 transition-all duration-300 hover:-translate-y-1 group relative overflow-hidden"
      >
        <!-- Shine effect on hover -->
        <div
          class="absolute inset-0 translate-x-[-100%] bg-gradient-to-r from-transparent via-white/40 to-transparent group-hover:animate-[shine_1.5s_ease-in-out]"
        >
        </div>
        <div
          class="w-14 h-14 bg-gradient-to-br from-polder-orange/10 to-transparent rounded-xl flex items-center justify-center mb-6 group-hover:from-polder-orange/20 group-hover:scale-110 transition-all duration-300 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8 text-polder-orange"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.263-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
            ></path>
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">
          {features[3].title}
        </h4>
        <p class="text-stone-600 leading-relaxed">
          {features[3].description}
        </p>
      </div>
    </div>
  </div>
</section>
