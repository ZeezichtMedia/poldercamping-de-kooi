---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  features?: Feature[];
}

const {
  title = "Waarom De Kooi?",
  subtitle = "Ervaar de luxe van <span class='text-polder-orange'>eenvoud</span>",
  features = [
    {
      title: "Privé Sanitair",
      description: "Geniet van uw eigen douche, toilet en wastafel direct bij de kampeerplek. Geen gedeelde voorzieningen, maar pure privacy."
    },
    {
      title: "Klein & Rustig",
      description: "Met slechts 7 kampeerplekken en 2 pipowagens ervaart u ultieme rust. Geen wifi, wel zingende vogels."
    },
    {
      title: "Unieke Locatie",
      description: "Midden in de polder, maar binnen 20 minuten fietsen op het Domplein van Utrecht. Het beste van twee werelden."
    },
    {
      title: "Polderleven",
      description: "Wakker worden met uitzicht op koeien, schapen en de Westbroekse molen. Een echte boerencamping ervaring."
    }
  ]
} = Astro.props;
---

<section class="py-20 bg-stone-50" id="features">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-polder-green text-lg font-bold uppercase tracking-wider mb-2">{title}</h2>
      <h3 class="text-3xl md:text-4xl font-bold text-stone-800" set:html={subtitle} />
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Feature 1 -->
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow group">
        <div class="w-14 h-14 bg-polder-green/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-polder-green/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-polder-green">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205 3 1m1.5.5-1.5-.5M6.75 7.364V3h-3v18m3-13.636 10.5-3.819" />
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">{features[0].title}</h4>
        <p class="text-stone-600 leading-relaxed">
          {features[0].description}
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow group">
        <div class="w-14 h-14 bg-polder-orange/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-polder-orange/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-polder-orange">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">{features[1].title}</h4>
        <p class="text-stone-600 leading-relaxed">
          {features[1].description}
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow group">
        <div class="w-14 h-14 bg-polder-green/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-polder-green/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-polder-green">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">{features[2].title}</h4>
        <p class="text-stone-600 leading-relaxed">
          {features[2].description}
        </p>
      </div>

      <!-- Feature 4 -->
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow group">
        <div class="w-14 h-14 bg-polder-orange/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-polder-orange/20 transition-colors">
           <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-polder-orange">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.263-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
        </div>
        <h4 class="text-xl font-bold text-stone-800 mb-3">{features[3].title}</h4>
        <p class="text-stone-600 leading-relaxed">
          {features[3].description}
        </p>
      </div>
    </div>
  </div>
</section>
