---
const currentLocale = Astro.currentLocale || 'nl';

const navTranslations = {
  nl: {
    home: 'Home',
    camping: 'De Camping',
    pipowagen: 'Pipowagen',
    omgeving: 'Omgeving',
    tarieven: 'Tarieven',
    contact: 'Contact',
    book: 'Boek Nu'
  },
  en: {
    home: 'Home',
    camping: 'The Camping',
    pipowagen: 'Gypsy Wagon',
    omgeving: 'Surroundings',
    tarieven: 'Rates',
    contact: 'Contact',
    book: 'Book Now'
  },
  de: {
    home: 'Home',
    camping: 'Der Camping',
    pipowagen: 'Zirkuswagen',
    omgeving: 'Umgebung',
    tarieven: 'Preise',
    contact: 'Kontakt',
    book: 'Jetzt buchen'
  }
};

const t = navTranslations[currentLocale];

function getLocaleUrl(locale, path) {
   if (locale === 'nl') return path;
   return `/${locale}${path}`;
}

const links = [
  { href: getLocaleUrl(currentLocale, '/'), label: t.home },
  { href: getLocaleUrl(currentLocale, '/camping'), label: t.camping },
  { href: getLocaleUrl(currentLocale, '/pipowagen'), label: t.pipowagen },
  { href: getLocaleUrl(currentLocale, '/omgeving'), label: t.omgeving },
  { href: getLocaleUrl(currentLocale, '/tarieven'), label: t.tarieven },
  { href: getLocaleUrl(currentLocale, '/contact'), label: t.contact },
];

const { pathname } = Astro.url;

function getLangUrl(targetLocale) {
  const parts = pathname.split('/').filter(Boolean);
  if (['en', 'de'].includes(parts[0])) {
    parts.shift();
  }
  const cleanPath = parts.join('/');
  
  if (targetLocale === 'nl') {
    return cleanPath ? `/${cleanPath}` : '/';
  }
  
  return `/${targetLocale}/${cleanPath}`;
}
---

<header class="bg-white/90 backdrop-blur-md sticky top-0 z-40 border-b border-stone-100 shadow-sm transition-all duration-300" id="main-header">
  <div class="container mx-auto px-4 h-20 flex items-center justify-between">
    <a href={getLocaleUrl(currentLocale, '/')} class="flex items-center gap-3 group relative z-50">
      <img src="/images/logo.png" alt="Poldercamping de Kooi Logo" class="w-16 h-16 object-contain" />
      <div class="flex flex-col">
        <span class="block text-polder-green font-bold text-lg leading-none group-hover:text-polder-orange transition-colors">Poldercamping</span>
        <span class="block text-polder-orange font-handwriting text-3xl leading-none transform -rotate-2 origin-left mt-1">De Kooi</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8">
      {links.map(link => (
        <a 
          href={link.href} 
          class="text-polder-green text-lg font-bold hover:text-polder-orange transition-colors"
        >
          {link.label}
        </a>
      ))}
      
      <!-- Language Switcher -->
      <div class="flex items-center gap-3 ml-4 border-l-2 border-stone-200 pl-6">
        <a 
          href={getLangUrl('nl')} 
          class={`text-base font-bold transition-colors ${currentLocale === 'nl' ? 'text-polder-orange' : 'text-stone-400 hover:text-polder-green'}`}
        >
          NL
        </a>
        <a 
          href={getLangUrl('en')} 
          class={`text-base font-bold transition-colors ${currentLocale === 'en' ? 'text-polder-orange' : 'text-stone-400 hover:text-polder-green'}`}
        >
          EN
        </a>
        <a 
          href={getLangUrl('de')} 
          class={`text-base font-bold transition-colors ${currentLocale === 'de' ? 'text-polder-orange' : 'text-stone-400 hover:text-polder-green'}`}
        >
          DE
        </a>
      </div>

      <a href={getLocaleUrl(currentLocale, currentLocale === 'nl' ? '/reserveren' : currentLocale === 'en' ? '/book' : '/reservieren')} class="bg-polder-orange hover:bg-polder-orange-dark text-white text-lg font-bold px-7 py-3 rounded-full transition-all hover:scale-105 shadow-md ml-4">
        {t.book}
      </a>
    </nav>

    <!-- Mobile Menu Toggle Button -->
    <button 
      id="mobile-menu-toggle" 
      class="lg:hidden relative z-50 p-2 text-polder-green hover:text-polder-orange transition-colors focus:outline-none focus:ring-2 focus:ring-polder-orange rounded-lg"
      aria-controls="mobile-menu" 
      aria-expanded="false" 
      aria-label="Toggle menu"
    >
      <div class="w-8 h-6 flex flex-col justify-between items-end overflow-hidden">
        <span class="w-full h-0.5 bg-current transform transition-all duration-300 origin-left" data-hamburger-line="1"></span>
        <span class="w-full h-0.5 bg-current transform transition-all duration-300" data-hamburger-line="2"></span>
        <span class="w-full h-0.5 bg-current transform transition-all duration-300 origin-left" data-hamburger-line="3"></span>
      </div>
    </button>
  </div>
</header>

<!-- Mobile Menu Container -->
<div 
  id="mobile-menu-backdrop" 
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 transition-opacity duration-300 opacity-0 pointer-events-none lg:hidden"
  aria-hidden="true"
></div>

<div 
  id="mobile-menu" 
  class="fixed inset-y-0 right-0 w-[85%] max-w-sm bg-white z-[51] transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden flex flex-col shadow-2xl overflow-y-auto"
  role="dialog" 
  aria-modal="true" 
  aria-label="Mobile navigation"
>
  <div class="pt-24 px-8 pb-8 flex flex-col h-full">
    <nav class="flex flex-col gap-6 items-center flex-1">
      {links.map((link, index) => (
        <a 
          href={link.href} 
          class="text-2xl font-bold text-polder-green hover:text-polder-orange transition-colors nav-link opacity-0 translate-y-4"
          style={`transition-delay: ${index * 50}ms`}
        >
          {link.label}
        </a>
      ))}
      
      <div class="flex items-center gap-8 mt-8 border-t border-stone-100 w-full justify-center pt-8 opacity-0 translate-y-4 nav-link" style="transition-delay: 300ms">
        <a href={getLangUrl('nl')} class={`text-lg font-bold ${currentLocale === 'nl' ? 'text-polder-orange' : 'text-stone-400 hover:text-polder-green'}`}>NL</a>
        <a href={getLangUrl('en')} class={`text-lg font-bold ${currentLocale === 'en' ? 'text-polder-orange' : 'text-stone-400 hover:text-polder-green'}`}>EN</a>
        <a href={getLangUrl('de')} class={`text-lg font-bold ${currentLocale === 'de' ? 'text-polder-orange' : 'text-stone-400 hover:text-polder-green'}`}>DE</a>
      </div>

      <a 
        href={getLocaleUrl(currentLocale, currentLocale === 'nl' ? '/reserveren' : currentLocale === 'en' ? '/book' : '/reservieren')} 
        class="mt-auto w-full text-center bg-polder-orange hover:bg-polder-orange-dark text-white px-8 py-4 rounded-xl text-xl font-bold shadow-lg transition-transform hover:scale-105 opacity-0 translate-y-4 nav-link"
        style="transition-delay: 350ms"
      >
        {t.book}
      </a>
    </nav>
  </div>
</div>

<style>
  /* Hamburger Animation Classes */
  :global(.menu-open) #mobile-menu-toggle [data-hamburger-line="1"] {
    transform: rotate(45deg);
  }
  :global(.menu-open) #mobile-menu-toggle [data-hamburger-line="2"] {
    opacity: 0;
    transform: translateX(-100%);
  }
  :global(.menu-open) #mobile-menu-toggle [data-hamburger-line="3"] {
    transform: rotate(-45deg);
  }

  /* Backdrop Open State */
  #mobile-menu-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Link Animations */
  #mobile-menu.is-open .nav-link {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
</style>

<script>
  function initMobileMenu() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const body = document.body;
    const links = menu?.querySelectorAll('a');

    // State
    let isOpen = false;

    function openMenu() {
      if (isOpen) return;
      isOpen = true;
      
      toggleBtn?.setAttribute('aria-expanded', 'true');
      
      // Use Tailwind utility classes for the transform logic
      menu?.classList.remove('translate-x-full');
      menu?.classList.add('translate-x-0', 'is-open'); 
      
      backdrop?.classList.add('is-open');
      document.documentElement.classList.add('menu-open');
      body.style.overflow = 'hidden';

      setTimeout(() => {
        const firstLink = menu?.querySelector('a');
        if (firstLink instanceof HTMLElement) firstLink.focus();
      }, 100);
    }

    function closeMenu() {
      if (!isOpen) return;
      isOpen = false;

      toggleBtn?.setAttribute('aria-expanded', 'false');
      
      // Revert Tailwind classes
      menu?.classList.remove('translate-x-0', 'is-open');
      menu?.classList.add('translate-x-full');
      
      backdrop?.classList.remove('is-open');
      document.documentElement.classList.remove('menu-open');
      body.style.overflow = '';
      
      toggleBtn?.focus();
    }

    function toggleMenu() {
      isOpen ? closeMenu() : openMenu();
    }

    // Refresh listeners to be robust
    const newToggleBtn = document.getElementById('mobile-menu-toggle');
    if (newToggleBtn) {
        const clone = newToggleBtn.cloneNode(true);
        newToggleBtn.replaceWith(clone);
        clone.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleMenu();
        });
    }

    backdrop?.addEventListener('click', closeMenu);

    links?.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    document.onkeydown = (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    };
    
    document.onclick = (e) => {
       if (isOpen && menu && !menu.contains(e.target as Node) && !toggleBtn?.contains(e.target as Node)) {
        closeMenu();
      }
    };
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
