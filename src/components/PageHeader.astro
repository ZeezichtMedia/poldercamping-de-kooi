---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imagePosition?: string;
}

const {
  title,
  subtitle,
  image = "/images/hero.png",
  imagePosition = "object-center",
} = Astro.props;
---

<section
  class="relative h-[40vh] min-h-[300px] flex items-center justify-center overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <img
      src={image}
      alt={title}
      class={`w-full h-full object-cover ${imagePosition}`}
    />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>
  <div class="relative z-10 text-center text-white p-4">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">{title}</h1>
    {
      subtitle && (
        <p class="text-xl md:text-2xl font-light opacity-90">{subtitle}</p>
      )
    }
  </div>
</section>
